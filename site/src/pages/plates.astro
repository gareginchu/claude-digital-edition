---
// Plates gallery page. Embeds the IIIF Presentation 3 manifest for the
// 23-page plates insert (pp. 549-571) of Chookaszian Vol. I via the Clover
// IIIF viewer. See iiif/README.md for pipeline and rights notes.
//
// Endings-Principles caveat: the viewer requires JS. This page therefore
// prints a full, JS-free fallback list (labels + captions + static thumbnails
// + a direct link to each plate JPEG) so the content is readable without a
// running Clover instance. The viewer is progressive enhancement.

import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

const repoRoot = path.resolve(process.cwd(), '..');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const manifestCandidates = [
  path.join(process.cwd(), 'public', 'iiif', 'manifest.json'),
  path.join(repoRoot, 'iiif', 'manifests', 'manifest.json'),
];
const manifestPath = manifestCandidates.find((p) => fs.existsSync(p));
const manifestUrl = `${base}/iiif/manifest.json`;

let manifest: any = null;
let canvases: any[] = [];
let manifestError: string | null = null;
if (manifestPath) {
  try {
    manifest = JSON.parse(fs.readFileSync(manifestPath, 'utf-8'));
    canvases = Array.isArray(manifest?.items) ? manifest.items : [];
  } catch (err: any) {
    manifestError = `Failed to parse ${manifestPath}: ${err.message}`;
  }
} else {
  manifestError = 'IIIF manifest not found. Run `python iiif/create_manifest.py` and copy the result to site/public/iiif/manifest.json.';
}

const pick = (labelObj: any, lang: string = 'en'): string => {
  if (!labelObj) return '';
  const values = labelObj[lang] || labelObj.hy || labelObj.none || Object.values(labelObj)[0];
  return Array.isArray(values) ? values.join(' ') : String(values || '');
};

const summary = pick(manifest?.summary);
const title = pick(manifest?.label) || 'Plates insert';
---
<BaseLayout title="Plates — Chookaszian Vol. I" currentPage="plates">

  <h1 style="font-size: clamp(1.8rem, 3vw, 2.6rem); line-height: 1.15; margin: 0 0 var(--space-3);">Plates</h1>
  {summary ? <p style="max-width: var(--measure); font-family: var(--font-sans); color: var(--ink-soft);">{summary}</p> : null}

  <aside style="background: var(--accent-tint); border-left: 4px solid var(--accent); padding: var(--space-4); margin: var(--space-5) 0; border-radius: var(--radius); font-family: var(--font-sans); font-size: .9rem;">
    <strong style="color: var(--accent);">Rights notice.</strong> These plates reproduce material
    from the printed Yerevan 2022/2023 edition (© Levon and Garegin Chugaszyan). The 10 miniatures
    originate from Matenadaran manuscripts and require per-image clearance.
    <em>Public visibility: pending rights clearance.</em>
    Do not redistribute tile assets or manifest URLs outside internal review contexts.
  </aside>

  {manifestError ? (
    <p style="font-family: var(--font-sans); color: var(--ink-mute);"><strong>Manifest unavailable.</strong> {manifestError}</p>
  ) : (
    <>
      <p style="font-family: var(--font-sans); font-size: .875rem; color: var(--ink-mute);">
        Manifest: <code>{manifestUrl}</code> — {canvases.length} canvases
      </p>

      <div id="clover-container" style="min-height: 640px; border: 1px solid var(--rule); margin-top: var(--space-4); background: white; border-radius: var(--radius);">
        <clover-iiif iiifContent={manifestUrl} viewerConfig='{"informationPanel":{"open":true,"renderAbout":true}}'></clover-iiif>
      </div>

      <script type="module" is:inline>
        const CLOVER_SRC = 'https://esm.sh/@samvera/clover-iiif@2.14.4?bundle';
        import(CLOVER_SRC).catch((err) => {
          console.error('Clover failed to load; falling back:', err);
          const el = document.getElementById('clover-container');
          if (el) el.innerHTML = '<p style="padding: 2rem; color: var(--ink-mute); font-family: var(--font-sans);">Viewer unavailable (Clover CDN not reachable). See the accessible list below.</p>';
        });
      </script>
    </>
  )}

  <h2 class="section-title">Plate index <small>JavaScript-free · WCAG-friendly</small></h2>
  <p style="max-width: var(--measure); font-family: var(--font-sans); font-size: .9rem; color: var(--ink-soft);">
    Every canvas from the manifest, mirrored as an accessible static list. Each thumbnail is the 256-px width variant;
    click a plate to open the full-resolution JPEG. Rendered even when Clover is unavailable.
  </p>

  {canvases.length === 0 ? (
    <p style="font-family: var(--font-sans); color: var(--ink-mute);"><em>No canvases found. Run the extraction and manifest scripts:</em></p>
    <pre style="background: var(--paper-alt); padding: var(--space-4); border: 1px solid var(--rule); border-radius: var(--radius); font-family: var(--font-mono); font-size: .85rem;">python iiif/extract_plates.py &amp;&amp; python iiif/build_tiles.py &amp;&amp; python iiif/create_manifest.py</pre>
  ) : (
    <ol style="list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-4); grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));">
      {canvases.map((c: any) => {
        const label = pick(c.label);
        const captionArm = pick(
          c.metadata?.find((m: any) => pick(m.label)?.startsWith('Caption'))?.value,
          'hy',
        );
        const pageMeta = pick(
          c.metadata?.find((m: any) => pick(m.label)?.startsWith('Source page'))?.value,
          'none',
        );
        const thumbId = c.thumbnail?.[0]?.id;
        const bodyId = c.items?.[0]?.items?.[0]?.body?.id;
        const seeAlsoTei = c.seeAlso?.find((s: any) => s.format?.includes('tei+xml'))?.id;
        return (
          <li id={`plate-${c.id.split('/').pop()}`} style="background: white; border: 1px solid var(--rule); border-radius: var(--radius); padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-3);">
            {thumbId ? <a href={bodyId} style="align-self: center;"><img src={thumbId} alt={label} loading="lazy" style="max-width: 100%; height: auto; border: 1px solid var(--rule); border-radius: var(--radius);" /></a> : null}
            <div>
              <strong style="font-family: var(--font-serif); font-size: 1.05rem;">{label}</strong>
              <div style="font-family: var(--font-sans); font-size: .8rem; color: var(--ink-mute); margin-top: var(--space-1);">{pageMeta}</div>
              <p lang="hy" style="font-family: var(--font-serif); margin-top: var(--space-3); font-size: .95rem;">{captionArm}</p>
              <p style="font-family: var(--font-sans); font-size: .8rem; margin-top: var(--space-3);">
                <a href={bodyId}>Full-resolution JPEG</a>
                {seeAlsoTei && <> · <a href={seeAlsoTei}>TEI msDesc</a></>}
              </p>
            </div>
          </li>
        );
      })}
    </ol>
  )}

</BaseLayout>
