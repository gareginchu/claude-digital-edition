---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

const candidateDirs = [
  path.join(process.cwd(), 'public', 'backmatter'),
  path.join(process.cwd(), '..', 'pipeline', 'backmatter'),
];

const backmatterDir = candidateDirs.find((dir) => fs.existsSync(dir));

function parseBackmatterFile(raw: string) {
  const lines = raw.split(/\r?\n/);
  let title = 'Back Matter';
  let sourcePages = 'unknown';
  let unit = 'unknown';
  let i = 0;

  while (i < lines.length && lines[i].startsWith('# ')) {
    const header = lines[i].slice(2).trim();
    if (!title || title === 'Back Matter') {
      title = header;
    } else if (header.toLowerCase().startsWith('source_pages:')) {
      sourcePages = header.split(':', 2)[1]?.trim() || sourcePages;
    } else if (header.toLowerCase().startsWith('source_unit:')) {
      unit = header.split(':', 2)[1]?.trim() || unit;
    }
    i += 1;
  }

  const body = lines.slice(i).join('\n').trim();
  return { title, sourcePages, unit, body };
}

let sections: any[] = [];
try {
  if (!backmatterDir) throw new Error('No backmatter directory found in expected locations.');
  const files = fs.readdirSync(backmatterDir).filter((f) => f.endsWith('.txt')).sort();
  sections = files.map((file) => {
    const raw = fs.readFileSync(path.join(backmatterDir, file), 'utf-8');
    return { file, ...parseBackmatterFile(raw) };
  });
} catch {
  sections = [];
}
---
<BaseLayout title="Back matter — Chookaszian Vol. I" currentPage="articles" lang="hy">

  <h1 style="font-size: clamp(1.8rem, 3vw, 2.6rem); line-height: 1.15; margin: 0 0 var(--space-3);">Back matter</h1>
  <p style="max-width: var(--measure); font-family: var(--font-sans); color: var(--ink-soft);">
    Structural units split from the printed volume's back matter (article_056 in the ToC-aligned segmentation):
    name index, plates gazetteer, and table of contents.
  </p>

  {sections.length === 0 ? (
    <p style="font-family: var(--font-sans); color: var(--ink-mute);"><em>No back-matter files found in pipeline/backmatter.</em></p>
  ) : (
    <div style="display: grid; gap: var(--space-6); margin-top: var(--space-6);">
      {sections.map((s: any) => (
        <section id={s.unit} style="border-top: 1px solid var(--rule); padding-top: var(--space-4);">
          <h2 style="font-family: var(--font-serif); font-size: 1.4rem; margin: 0 0 var(--space-2);">{s.title}</h2>
          <p style="font-family: var(--font-sans); font-size: .8rem; color: var(--ink-mute); margin: 0 0 var(--space-4);">
            Unit: <code>{s.unit}</code> · pp. {s.sourcePages} · <code>{s.file}</code>
          </p>
          <pre lang="hy" style="white-space: pre-wrap; font-family: var(--font-serif); font-size: .95rem; background: var(--paper-alt); border: 1px solid var(--rule); padding: var(--space-4); border-radius: var(--radius); line-height: 1.5;">{s.body}</pre>
        </section>
      ))}
    </div>
  )}

</BaseLayout>
