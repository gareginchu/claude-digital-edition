---
// This component lists only article pages from site/html.
import fs from 'fs';
import path from 'path';

const htmlDir = new URL('../../html', import.meta.url);
let files = [];
try {
  files = fs
    .readdirSync(htmlDir)
    .filter(f => /^article_\d{3}\.html$/.test(f));
} catch (e) {
  files = [];
}
---
<div>
  <h2>Article Pages (001-056)</h2>
  <ul>
    {files.length === 0 ? (
      <li>No article HTML found in /site/html</li>
    ) : (
      files.map(f => <li><a href={`./articles/${f}`}>{f}</a></li>)
    )}
  </ul>
</div>
